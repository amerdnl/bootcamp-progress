<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bulletin Board</title>
</head>
<body>
    <h2>Post List</h2>
    <% posts.forEach(post => { %>
    
        <div>
            <h2><%= post.title %></h2>
            <p><%= post.content %></p>
        </div>
    
    
    <% }) %>
</body>
</html>